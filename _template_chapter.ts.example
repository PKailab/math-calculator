import { Chapter } from './types';

/**
 * ============================================================================
 * 📝 TEMPLATE FOR NEW CHAPTERS (नए चैप्टर के लिए टेम्पलेट)
 * ============================================================================
 * भविष्य में कोई भी नया चैप्टर जोड़ने के लिए:
 * 1. इस फाइल को कॉपी करें और नया नाम दें (जैसे: ch6_triangles.ts)
 * 2. नीचे दिए गए 'id', 'title', 'inputGuide' आदि को बदलें।
 * 3. 'solve' फंक्शन के अंदर अपना गणित का लॉजिक लिखें।
 * 4. बस! आपको कहीं और कुछ भी import/export करने की जरूरत नहीं है।
 */

export const chapterTemplate: Chapter = {
  // 1. यूनिक ID (जैसे "ch6")
  id: "ch_template",
  
  // 2. चैप्टर का नाम जो स्क्रीन पर दिखेगा
  title: "Chapter X: नया चैप्टर",
  
  // 3. यूज़र को क्या टाइप करना है, उसका निर्देश
  inputGuide: "मान डालें (उदा: 5,10)",
  
  // 4. इस चैप्टर का अपना कीबोर्ड (5 पंक्तियाँ, 5 कॉलम)
  // जो बटन खाली रखना हो, वहाँ "" लिखें।
  keyboardLayout: [
    ["-", ",", "DEL", "AC"],
    ["7", "8", "9", ""],
    ["4", "5", "6", ""],
    ["1", "2", "3", "SOLVE"],
    ["0", ".", "", ""]
  ],
  
  // 5. मुख्य लॉजिक (यहाँ आपका गणित का कोड आएगा)
  solve: (inputStr: string, isShort: boolean) => {
    // इनपुट को कॉमा (,) से अलग करना
    const parts = inputStr.split(",");
    
    // अगर इनपुट गलत है तो एरर दें
    if (parts.length !== 2) {
      return "त्रुटि: कृपया 2 मान डालें। उदाहरण: 5,10";
    }

    // स्ट्रिंग को नंबर में बदलना
    const a = parseFloat(parts[0]);
    const b = parseFloat(parts[1]);

    // अगर नंबर नहीं है तो एरर दें
    if (isNaN(a) || isNaN(b)) {
      return "त्रुटि: कृपया सही संख्याएं डालें।";
    }

    // --- यहाँ अपना गणित का लॉजिक लिखें ---
    const result = a + b;

    // अगर यूज़र ने 'Short Ans' चुना है
    if (isShort) {
      return `उत्तर = ${result}`;
    }

    // अगर यूज़र ने 'Full Steps' चुना है (डिफ़ॉल्ट)
    return `हल (Solution):

Step 1: दिया गया है
a = ${a}
b = ${b}

Step 2: सूत्र का प्रयोग
योग = a + b
योग = ${a} + ${b}

अंतिम उत्तर:
${result}`;
  }
};
